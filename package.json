{
  "name": "sift",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Job Radar — self-hosted, single-user ATS job aggregator.",
  "scripts": {
    "ingest": "tsx src/ingest/run.ts",
    "build:logos": "tsx scripts/fetch-logos.ts",
    "build:browser": "tsx scripts/build-company-browser.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.3.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
