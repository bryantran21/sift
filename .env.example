# Copy to .env.local and fill in. Never commit the real file.

# Postgres. Railway provides this in production; for local dev use a local install
# or a hosted dev branch (Neon, Supabase, Railway). Not needed for `pnpm ingest`
# in Phase 1 (console-only), but required from Phase 2 onward (persistence).
DATABASE_URL=postgres://user:password@localhost:5432/sift

# Optional: LLM key for the Stage-2 classification fallback (Phase 9). Unused for now.
# ANTHROPIC_API_KEY=
